# Uygulamanın çalışması için gereken hassas ve ortama özel bilgileri kod dosyalarının dışında tutan özel bir config dosyası. 
# Şifre, port numaraları, gizli anahtarlar — bunları doğrudan koda yazman hem güvensiz hem de esnek değil. .env bu sorunu çözer.
#🔌 Veritabanı Bağlantı Bilgileri
DB_HOST=localhost
# MySQL sunucusu nerede? → localhost yani kendi bilgisayarında. Uzak bir sunucu olsaydı IP adresi yazılırdı.
DB_PORT=3306
# MySQL'in dinlediği kapı numarası. 3306, MySQL'in evrensel varsayılan portu — sen değiştirmediysen bu böyle kalır.
DB_NAME=pitwall
# Bağlanılacak veritabanının adı. Az önce CREATE DATABASE pitwall ile oluşturduğun şey tam olarak bu.
DB_USER=root
DB_PASSWORD=030905Bsql
# MySQL'e bağlanmak için kimlik bilgileri. Uygulama, senin yerine bu kullanıcıyla login olacak.

JWT_SECRET=pitwall_gizli_anahtar_2025_xyz
# JWT = JSON Web Token → kullanıcı giriş yaptığında ona verilen şifreli kimlik kartı.
# Bu SECRET, o kartı imzalamak ve doğrulamak için kullanılan gizli anahtar. Ne kadar uzun ve karmaşık olursa o kadar güvenli.
# Bunu bilen biri sahte token üretebilir — asla paylaşılmaz, asla koda yazılmaz.
PORT=3001
# Backend sunucunun hangi kapıdan dinleyeceği. 
# Tarayıcı veya frontend localhost:3001'e istek attığında uygulaman cevap verecek.